{
  "manifestVersion": 1,
  "id": "terragrunt-task",
  "name": "Terragrunt Tasks",
  "version": "0.0.1",
  "publisher": "your-publisher",
  "targets": [
    {
      "id": "Microsoft.VisualStudio.Services"
    }
  ],
  "description": "Azure DevOps pipeline tasks for Terragrunt: install and run arbitrary Terragrunt commands.",
  "categories": ["Build and release"],
  "icons": {
    "default": "images/icon.png"
  },
  "files": [
    {
      "path": "buildTasks/terragrunt"
    }
  ],
  "contributions": [
    {
      "id": "terragrunt-task",
      "type": "ms.vss-distributed-task.task",
      "properties": {
        "name": "buildTasks/terragrunt/task.json"
      }
    }
  ]
}
